local colors = require("colors")
local settings = require("settings")
local app_icons = require("helpers.app_icons")

local workspace_icons = {
  General = "􀎞",
  Work = "􀈮",
  Dev = "􀙚",
  Media = "􀊖",
  Game = "􀛸",
  Ghostty = "􀪏",
  Kitty = "􀪏",
  Zed = "􀤸",
  IntellijIDEA = "􀤷",
  Obsidian = "􀈕",
  Claude = "􀌪",
  External = "􀢹",
  Zen = "􀎬",
}

local MAX_APP_ITEMS = 12

local current_workspace_name = "General"
local current_workspace_id = nil
local current_front_app = ""
local app_item_pool = {}

local function trim(value)
  if type(value) ~= "string" then
    return value
  end

  return value:gsub("^%s+", ""):gsub("%s+$", "")
end

local function first(tbl, keys)
  if type(tbl) ~= "table" then
    return nil
  end

  for _, key in ipairs(keys) do
    local value = tbl[key]
    if value ~= nil then
      return value
    end
  end

  return nil
end

local function stringify(value)
  if value == nil then
    return nil
  end

  return tostring(value)
end

local function row_is_active(row)
  return first(row, { "is_active", "active", "focused", "is_current", "current" }) == true
end

local function workspace_name_from_row(row)
  return trim(first(row, { "workspace_name", "name", "label" }))
end

local function workspace_id_from_row(row)
  return stringify(first(row, { "workspace_id", "id", "idx" }))
end

local function window_workspace_id(row)
  return stringify(first(row, { "workspace_id", "id" }))
end

local function pid_from_row(row)
  return stringify(first(row, { "pid", "process_id" }))
end

local function icon_for_app(app_name)
  return app_icons[app_name] or app_icons["Default"] or ":default:"
end

sbar.add("event", "rift_workspace_changed")
sbar.add("event", "rift_windows_changed")

local space_display = sbar.add("item", "space.display", {
  icon = {
    font = { family = settings.font.numbers },
    string = "􀎞 General",
    padding_left = 12,
    padding_right = 12,
    color = colors.flash,
  },
  label = { drawing = false },
  padding_right = 1,
  padding_left = 1,
  background = {
    color = colors.bg1,
    border_width = 1,
    height = 26,
    border_color = colors.flash,
  },
})

local space_bracket = sbar.add("bracket", { space_display.name }, {
  background = {
    color = colors.transparent,
    border_color = colors.purple,
    height = 28,
    border_width = 2,
  },
})

for i = 1, MAX_APP_ITEMS do
  local item = sbar.add("item", "space.app." .. i, {
    icon = {
      font = "sketchybar-app-font:Regular:16.0",
      string = "",
      color = colors.grey,
      padding_left = 4,
      padding_right = 4,
      y_offset = -1,
    },
    label = { drawing = false },
    background = { drawing = false },
    padding_left = 1,
    padding_right = 1,
    drawing = false,
  })

  app_item_pool[i] = { item = item, app_name = nil }
end

sbar.add("item", "space.padding.display", {
  width = settings.group_paddings,
})

local function render_workspace(name)
  if not name or name == "" then
    return
  end

  current_workspace_name = name

  local icon = workspace_icons[name] or "􀎞"
  space_display:set({
    icon = { string = icon .. " " .. name },
  })
end

local function highlight_front_app(app_name)
  for i = 1, MAX_APP_ITEMS do
    local entry = app_item_pool[i]
    local is_focused = entry.app_name ~= nil and entry.app_name == app_name
    entry.item:set({
      icon = { color = is_focused and colors.flash or colors.grey },
    })
  end
end

local function clear_app_icons()
  for i = 1, MAX_APP_ITEMS do
    local entry = app_item_pool[i]
    entry.item:set({ drawing = false })
    entry.app_name = nil
  end
end

local function render_app_icons(app_names)
  for i = 1, MAX_APP_ITEMS do
    local entry = app_item_pool[i]
    local app_name = app_names[i]

    if app_name then
      entry.app_name = app_name
      entry.item:set({
        drawing = true,
        icon = {
          string = icon_for_app(app_name),
          color = app_name == current_front_app and colors.flash or colors.grey,
        },
      })
    else
      entry.item:set({ drawing = false })
      entry.app_name = nil
    end
  end
end

local function build_pid_to_app_map(app_rows)
  local pid_to_app = {}

  if type(app_rows) ~= "table" then
    return pid_to_app
  end

  for _, row in ipairs(app_rows) do
    local pid = pid_from_row(row)
    local app_name = trim(first(row, {
      "name",
      "app_name",
      "application_name",
      "display_name",
      "localized_name",
    }))

    if pid and app_name and app_name ~= "" then
      pid_to_app[pid] = app_name
    end
  end

  return pid_to_app
end

local function resolve_window_app_name(window_row, pid_to_app)
  local direct_name = trim(first(window_row, {
    "app_name",
    "application_name",
    "owner_name",
    "name",
  }))

  if direct_name and direct_name ~= "" then
    return direct_name
  end

  local pid = pid_from_row(window_row)
  if pid and pid_to_app[pid] then
    return pid_to_app[pid]
  end

  return nil
end

local function refresh_workspace_apps()
  if not current_workspace_id then
    clear_app_icons()
    return
  end

  sbar.exec("rift-cli query applications 2>/dev/null", function(application_rows)
    local pid_to_app = build_pid_to_app_map(application_rows)

    sbar.exec("rift-cli query windows 2>/dev/null", function(window_rows)
      if type(window_rows) ~= "table" then
        clear_app_icons()
        return
      end

      local app_names = {}
      local seen = {}

      for _, row in ipairs(window_rows) do
        if window_workspace_id(row) == current_workspace_id then
          local app_name = resolve_window_app_name(row, pid_to_app)
          if app_name and not seen[app_name] then
            seen[app_name] = true
            table.insert(app_names, app_name)
          end
        end
      end

      render_app_icons(app_names)
    end)
  end)
end

local function refresh_workspace_state()
  sbar.exec("rift-cli query workspaces 2>/dev/null", function(rows)
    if type(rows) ~= "table" then
      render_workspace(current_workspace_name)
      clear_app_icons()
      return
    end

    local active_row = nil
    for _, row in ipairs(rows) do
      if row_is_active(row) then
        active_row = row
        break
      end
    end

    active_row = active_row or rows[1]
    if not active_row then
      clear_app_icons()
      return
    end

    current_workspace_id = workspace_id_from_row(active_row)
    render_workspace(workspace_name_from_row(active_row) or current_workspace_name)
    refresh_workspace_apps()
  end)
end

space_display:subscribe("rift_workspace_changed", function(env)
  current_workspace_id = stringify(env.RIFT_WORKSPACE_ID) or current_workspace_id
  render_workspace(trim(env.RIFT_WORKSPACE_NAME) or current_workspace_name)
  refresh_workspace_apps()
end)

space_display:subscribe("rift_windows_changed", function(env)
  if stringify(env.RIFT_WORKSPACE_ID) == current_workspace_id
    or trim(env.RIFT_WORKSPACE_NAME) == current_workspace_name then
    refresh_workspace_apps()
  end
end)

space_display:subscribe("front_app_switched", function(env)
  current_front_app = trim(env.INFO) or ""
  highlight_front_app(current_front_app)
end)

sbar.exec(
  "osascript -e 'tell application \"System Events\" to get name of first application process whose frontmost is true'",
  function(app_result)
    current_front_app = trim(app_result) or ""
    refresh_workspace_state()
  end
)

return {
  space_display = space_display,
  space_bracket = space_bracket,
}
