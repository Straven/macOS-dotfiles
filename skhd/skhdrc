# ============================================================
# skhd-zig configuration for yabai
# Mode map (matches former AeroSpace setup):
#   hyper-n → nav     focus + warp windows
#   hyper-w → win     layout, fullscreen, float
#   hyper-z → resize  resize windows
#   hyper-s → space   focus space + send window
#   hyper-a → app     app launcher (auto-exits)
#   hyper-r → reload  yabai/sketchybar/skhd reload (auto-exits)
# Hyper = cmd+ctrl+alt+shift (Caps Lock via Karabiner)
# ============================================================

:: default
:: nav     @
:: win     @
:: resize  @
:: spc     @
:: app     @
:: reload  @

# ── Hyper triggers ──────────────────────────────────────────
hyper - n ; nav
hyper - w ; win
hyper - z ; resize
hyper - s ; spc
hyper - a ; app
hyper - r ; reload

# ============================================================
# NAV mode  (focus + warp)
# ============================================================
nav < escape ; default
nav < return ; default

nav < h : yabai -m window --focus west
nav < j : yabai -m window --focus south
nav < k : yabai -m window --focus north
nav < l : yabai -m window --focus east

nav < shift - h : yabai -m window --warp west
nav < shift - j : yabai -m window --warp south
nav < shift - k : yabai -m window --warp north
nav < shift - l : yabai -m window --warp east

nav < shift - tab : yabai -m window --display next; yabai -m display --focus next

# ============================================================
# WIN mode  (layout + float + fullscreen)
# ============================================================
win < escape ; default
win < return ; default

win < f      ; default : yabai -m window --toggle zoom-fullscreen
win < space  ; default : yabai -m window --toggle float
win < s      ; default : yabai -m space --layout stack
win < w      ; default : yabai -m space --layout stack
win < e      ; default : yabai -m space --layout bsp

# ============================================================
# RESIZE mode  (h/j/k/l ±50, shift ±200)
# ============================================================
resize < escape ; default
resize < return ; default

resize < h : yabai -m window --resize left:-50:0
resize < l : yabai -m window --resize right:50:0
resize < j : yabai -m window --resize bottom:0:50
resize < k : yabai -m window --resize top:0:-50

resize < shift - h : yabai -m window --resize left:-200:0
resize < shift - l : yabai -m window --resize right:200:0
resize < shift - j : yabai -m window --resize bottom:0:200
resize < shift - k : yabai -m window --resize top:0:-200

# ============================================================
# SPC mode  (focus + move-window)  — named "spc" because "space" clashes with the skhd key name
# ============================================================
spc <escape ; default

# Focus by label
spc <1 ; default : yabai -m space --focus General
spc <2 ; default : yabai -m space --focus Work
spc <3 ; default : yabai -m space --focus Dev
spc <4 ; default : yabai -m space --focus Media
spc <5 ; default : yabai -m space --focus Game
spc <6 ; default : yabai -m space --focus External
spc <7 ; default : yabai -m space --focus Zen
spc <8 ; default : yabai -m space --focus Scratch1
spc <9 ; default : yabai -m space --focus Scratch2
spc <g ; default : yabai -m space --focus Ghostty
spc <k ; default : yabai -m space --focus Kitty
spc <z ; default : yabai -m space --focus Zed
spc <i ; default : yabai -m space --focus IntellijIDEA
spc <o ; default : yabai -m space --focus Obsidian
spc <c ; default : yabai -m space --focus Claude

spc <left  ; default : yabai -m space --focus prev
spc <right ; default : yabai -m space --focus next

# Move window to space (no follow)
spc <shift - 1 ; default : yabai -m window --space General
spc <shift - 2 ; default : yabai -m window --space Work
spc <shift - 3 ; default : yabai -m window --space Dev
spc <shift - 4 ; default : yabai -m window --space Media
spc <shift - 5 ; default : yabai -m window --space Game
spc <shift - 6 ; default : yabai -m window --space External
spc <shift - 7 ; default : yabai -m window --space Zen
spc <shift - 8 ; default : yabai -m window --space Scratch1
spc <shift - 9 ; default : yabai -m window --space Scratch2
spc <shift - g ; default : yabai -m window --space Ghostty
spc <shift - k ; default : yabai -m window --space Kitty
spc <shift - z ; default : yabai -m window --space Zed
spc <shift - i ; default : yabai -m window --space IntellijIDEA
spc <shift - o ; default : yabai -m window --space Obsidian
spc <shift - c ; default : yabai -m window --space Claude

# ============================================================
# APP mode  (launcher; auto-exits)
# ============================================================
app < escape ; default
app < return ; default

app < t ; default : osascript -e 'tell application "Ghostty" to activate' -e 'tell application "System Events" to keystroke "n" using command down'
app < g ; default : open -a Ghostty
app < k ; default : open -a Kitty
app < o ; default : open -a Obsidian
app < b ; default : open -a Safari
app < z ; default : open -a Zed
app < v ; default : open -a VSCodium
app < n ; default : open -a Notes
app < f ; default : open -a Finder
app < w ; default : open -a Wallabag
app < s ; default : open -a Spotify
app < m ; default : open -a Music
app < c ; default : open -a Claude
app < h ; default : open -a NAPS2
app < i ; default : open -a "IntelliJ IDEA"
app < shift - b ; default : open -a Zen

# ============================================================
# RELOAD mode  (auto-exits)
# ============================================================
reload < escape ; default
reload < return ; default

reload < a ; default : yabai --restart-service
reload < s ; default : sketchybar --reload
reload < r ; default : yabai --restart-service && sketchybar --reload
reload < k ; default : skhd --restart-service
