# Hyper = Caps via Karabiner = cmd + ctrl + alt + shift
# Rift owns WM/workspace bindings and workspace-aware app placement.
# skhd-zig is only kept for the modal app launcher because Rift has direct
# key bindings, but no modal submaps like the old AeroSpace app mode.

:: default
:: app @
:: reload @

hyper - a ; app
hyper - r ; reload

# ============================================================
# APP MODE
# ============================================================
app < escape ; default
app < return ; default

# New Ghostty window on the Ghostty workspace.
app < t : ~/.config/skhd/scripts/rift_launch.sh "Ghostty" 5; osascript -e 'tell application "Ghostty" to activate' -e 'tell application "System Events" to keystroke "n" using command down'
app < hyper - t : ~/.config/skhd/scripts/rift_launch.sh "Ghostty" 5; osascript -e 'tell application "Ghostty" to activate' -e 'tell application "System Events" to keystroke "n" using command down'

# Open apps on their Rift workspace when they have one.
app < g : ~/.config/skhd/scripts/rift_launch.sh "Ghostty" 5
app < hyper - g : ~/.config/skhd/scripts/rift_launch.sh "Ghostty" 5

app < k : ~/.config/skhd/scripts/rift_launch.sh "Kitty" 6
app < hyper - k : ~/.config/skhd/scripts/rift_launch.sh "Kitty" 6

app < o : ~/.config/skhd/scripts/rift_launch.sh "Obsidian" 9
app < hyper - o : ~/.config/skhd/scripts/rift_launch.sh "Obsidian" 9

app < b : ~/.config/skhd/scripts/rift_launch.sh "Safari" 0
app < hyper - b : ~/.config/skhd/scripts/rift_launch.sh "Safari" 0

app < z : ~/.config/skhd/scripts/rift_launch.sh "Zed" 7
app < hyper - z : ~/.config/skhd/scripts/rift_launch.sh "Zed" 7

app < v : ~/.config/skhd/scripts/rift_launch.sh "VSCodium" 2
app < hyper - v : ~/.config/skhd/scripts/rift_launch.sh "VSCodium" 2

app < n : open -a "Notes"
app < hyper - n : open -a "Notes"

app < f : open -a "Finder"
app < hyper - f : open -a "Finder"

app < w : open -a "Wallabag"
app < hyper - w : open -a "Wallabag"

app < s : ~/.config/skhd/scripts/rift_launch.sh "Spotify" 3
app < hyper - s : ~/.config/skhd/scripts/rift_launch.sh "Spotify" 3

app < m : ~/.config/skhd/scripts/rift_launch.sh "Music" 3
app < hyper - m : ~/.config/skhd/scripts/rift_launch.sh "Music" 3

app < c : ~/.config/skhd/scripts/rift_launch.sh "Claude" 10
app < hyper - c : ~/.config/skhd/scripts/rift_launch.sh "Claude" 10

app < h : open -a "NAPS2"
app < hyper - h : open -a "NAPS2"

app < i : ~/.config/skhd/scripts/rift_launch.sh "IntelliJ IDEA" 8
app < hyper - i : ~/.config/skhd/scripts/rift_launch.sh "IntelliJ IDEA" 8

app < shift - b : ~/.config/skhd/scripts/rift_launch.sh "Zen" 12
app < hyper + shift - b : ~/.config/skhd/scripts/rift_launch.sh "Zen" 12

# ============================================================
# RELOAD MODE
# ============================================================
reload < escape ; default
reload < return ; default

reload < s : sketchybar --reload
reload < k : skhd --reload
reload < r : rift-cli service restart
