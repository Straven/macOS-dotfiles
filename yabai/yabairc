#!/usr/bin/env bash

yabai -m signal --add event=dock_did_restart action="sudo yabai --load-sa"
sudo yabai --load-sa
# ==============================================================================
# yabai configuration — SIP enabled (no scripting addition)
# ==============================================================================

# ==============================================================================
# Global settings
# ==============================================================================

# Default layout (per-space stack overrides applied via spaces.sh)
yabai -m config layout bsp

# Window appearance
yabai -m config window_shadow float
yabai -m config window_opacity on
yabai -m config window_opacity_duration 0.0
yabai -m config active_window_opacity 1.0
yabai -m config normal_window_opacity 1.0

# Mouse support
yabai -m config mouse_follows_focus on
yabai -m config focus_follows_mouse off
yabai -m config mouse_modifier fn
yabai -m config mouse_action1 move
yabai -m config mouse_action2 resize
yabai -m config mouse_drop_action swap

# Window placement
yabai -m config window_origin_display default
yabai -m config window_placement second_child
yabai -m config window_zoom_persist on

# Split settings
yabai -m config split_ratio 0.50
yabai -m config split_type auto
yabai -m config auto_balance off

# Padding and gaps
yabai -m config top_padding 7
yabai -m config bottom_padding 7
yabai -m config left_padding 7
yabai -m config right_padding 7
yabai -m config window_gap 7

# External bar (40px sketchybar + 8px padding)
yabai -m config external_bar all:48:0

# Insert feedback color (Tokyo Night Flash yellow)
yabai -m config insert_feedback_color 0xfff5e642

# ==============================================================================
# Apply space labels FIRST so subsequent rules can reference labels
# ==============================================================================

"$HOME/.config/yabai/spaces.sh"

# ==============================================================================
# Application rules — workspace assignment
# ==============================================================================

# Note: yabai rule API requires space INDEX, not label. Map below mirrors
# spaces.sh order. If Mission Control reorders, both this and spaces.sh
# need updating.
#   1 General  2 Work  3 Dev  4 Media  5 Game  6 Ghostty  7 Kitty
#   8 Zed  9 IntellijIDEA  10 Obsidian  11 Claude  12 External  13 Zen
#   14 Scratch1  15 Scratch2

# General (1) — default browsers
yabai -m rule --add app="^Safari$" space=1
yabai -m rule --add app="^Firefox$" space=1

# Dev (3)
yabai -m rule --add app="^VSCodium$" space=3

# Media (4)
yabai -m rule --add app="^Spotify$" space=4
yabai -m rule --add app="^Music$" space=4

# Ghostty (6)
yabai -m rule --add app="^Ghostty$" space=6
yabai -m rule --add app="^cmux$" space=6

# Kitty (7)
yabai -m rule --add app="^kitty$" space=7

# Zed (8)
yabai -m rule --add app="^Zed$" space=8

# IntellijIDEA (9)
yabai -m rule --add app="^IntelliJ IDEA$" space=9

# Obsidian (10)
yabai -m rule --add app="^Obsidian$" space=10

# Claude (11)
yabai -m rule --add app="^Claude$" space=11

# Zen (13)
yabai -m rule --add app="^Zen$" space=13
yabai -m rule --add app="^Zen Browser$" space=13

# ==============================================================================
# Float rules — system + dialog windows
# ==============================================================================

yabai -m rule --add app="^System Settings$" manage=off
yabai -m rule --add app="^System Preferences$" manage=off
yabai -m rule --add app="^System Information$" manage=off
yabai -m rule --add app="^Activity Monitor$" manage=off
yabai -m rule --add app="^Calculator$" manage=off
yabai -m rule --add app="^Archive Utility$" manage=off
yabai -m rule --add app="^Disk Utility$" manage=off
yabai -m rule --add app="^App Store$" manage=off
yabai -m rule --add app="^Time Machine$" manage=off

yabai -m rule --add app="^Finder$" title="(Copy|Connect|Move|Info|Pref)" manage=off

yabai -m rule --add title="^Preferences$" manage=off
yabai -m rule --add title="^Settings$" manage=off

# ==============================================================================
# Signals — sketchybar integration
# ==============================================================================

yabai -m signal --add event=space_changed action="sketchybar --trigger space_change"
yabai -m signal --add event=display_changed action="sketchybar --trigger display_change"
yabai -m signal --add event=window_focused action="sketchybar --trigger window_focus"
yabai -m signal --add event=window_title_changed action="sketchybar --trigger title_change"

# ==============================================================================
# Signals — opacity script
# ==============================================================================

yabai -m signal --add event=window_focused action="$HOME/.config/yabai/scripts/window_opacity.sh"
yabai -m signal --add event=window_created action="$HOME/.config/yabai/scripts/window_opacity.sh"

echo "yabai configuration loaded"
